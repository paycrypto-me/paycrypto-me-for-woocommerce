msgid "Lightning Node Type"
msgstr "Tipo de Nodo Lightning"

#: includes/class-wc-gateway-paycrypto-me-lightning.php:109
msgid "Invoice Expiry"
msgstr "Vencimiento de Factura"

#: includes/class-wc-gateway-paycrypto-me-lightning.php:111
msgid ""
"Time before invoice expires. Min: 300 (5 min), Max: 86400 (24h). Default: "
"3600 (1 hour)"
msgstr ""
"Tiempo antes de que expire la factura. Mín: 300 (5 min), Máx: 86400 (24 h). "
"Predeterminado: 3600 (1 hora)"

