#. Plugin Name of the plugin
#: paycrypto-me-for-woocommerce.php
msgid "PayCrypto.Me for WooCommerce"
msgstr "PayCrypto.Me para WooCommerce"

#. Plugin URI of the plugin
#: paycrypto-me-for-woocommerce.php
msgid "https://github.com/paycrypto-me/paycrypto-me-for-woocommerce/"
msgstr "https://github.com/paycrypto-me/paycrypto-me-for-woocommerce/"

#. Description of the plugin
#: paycrypto-me-for-woocommerce.php
msgid ""
"PayCrypto.Me for WooCommerce lets your store accept Bitcoin payments — On-"
"Chain and Lightning Network — directly into wallets and nodes you control."
msgstr ""
"PayCrypto.Me para WooCommerce permite que tu tienda acepte pagos en Bitcoin — "
"On-Chain y Lightning Network — directamente en carteras y nodos que controlas."

#. Author of the plugin
#: paycrypto-me-for-woocommerce.php
msgid "PayCrypto.Me"
msgstr "PayCrypto.Me"

#. Author URI of the plugin
#: paycrypto-me-for-woocommerce.php
msgid "https://paycrypto.me/"
msgstr "https://paycrypto.me/"

