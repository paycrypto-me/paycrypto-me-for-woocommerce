#!/bin/bash
set -e

WP_SERVICE="wordpress"
WP_PATH="/var/www/html"

wp_up() {
  docker compose -f ./docker-compose.yml up -d --force-recreate
}

dc_exec() {
  docker compose -f ./docker-compose.yml exec -T "$WP_SERVICE" "$@"
}

wp_exec() {
  docker compose -f ./docker-compose.yml exec -T "$WP_SERVICE" wp "$@" --path="$WP_PATH" --allow-root
}

echo "🚀 Iniciando o setup do PayCrypto.Me WooCommerce..."
wp_up

# Aguarda o entrypoint do container terminar de copiar os arquivos do WP para o volume
echo "⏳ Aguardando arquivos do WordPress..."
until dc_exec test -f "$WP_PATH/wp-includes/version.php" 2>/dev/null; do
  echo "  arquivos ainda não prontos, aguardando 3s..."
  sleep 3
done

# Aguarda o MySQL aceitar conexões TCP (porta abre só quando está pronto para autenticar)
echo "⏳ Aguardando banco de dados..."
until dc_exec bash -c "echo > /dev/tcp/wp_db/3306" 2>/dev/null; do
  echo "  banco ainda não disponível, aguardando 3s..."
  sleep 3
done

echo "⏳ Verificando se o WordPress está instalado..."
if wp_exec core is-installed 2>/dev/null; then
  echo "✅ WordPress já instalado."
else
  echo "⚙️ Instalando WordPress..."
  wp_exec core install \
    --url="http://localhost:8080" \
    --title="PayCrypto.Me" \
    --admin_user="admin" \
    --admin_password="admin123" \
    --admin_email="admin@example.com" \
    --skip-email
fi

echo "📦 Verificando WooCommerce..."
if wp_exec plugin is-installed woocommerce 2>/dev/null; then
  echo "✅ WooCommerce já instalado."
  wp_exec plugin activate woocommerce 2>/dev/null || true
else
  echo "  baixando WooCommerce (requer acesso à internet)..."
  PLUGIN_ZIP=$(dc_exec mktemp -p /tmp woocommerce.XXXXXX.zip)
  if dc_exec bash -c "cd /tmp && curl -fSL https://downloads.wordpress.org/plugin/woocommerce.zip -o ${PLUGIN_ZIP##*/} 2>&1" && \
     dc_exec unzip -q "${PLUGIN_ZIP}" -d "$WP_PATH/wp-content/plugins/" && \
     wp_exec plugin activate woocommerce; then
    echo "✅ WooCommerce instalado e ativado."
  else
    echo "⚠️  Falha ao baixar WooCommerce. Verifique a conexão de rede."
    echo "   Dica: verifique com 'docker compose exec -T wordpress curl https://downloads.wordpress.org/plugin/woocommerce.zip -I'"
  fi
fi

echo "🎨 Verificando tema Storefront..."
if wp_exec theme is-installed storefront 2>/dev/null; then
  echo "✅ Storefront já instalado."
  wp_exec theme activate storefront 2>/dev/null || true
else
  echo "  baixando Storefront (requer acesso à internet)..."
  THEME_ZIP=$(dc_exec mktemp -p /tmp storefront.XXXXXX.zip)
  if dc_exec bash -c "cd /tmp && curl -fSL https://downloads.wordpress.org/theme/storefront.zip -o ${THEME_ZIP##*/} 2>&1" && \
     dc_exec unzip -q "${THEME_ZIP}" -d "$WP_PATH/wp-content/themes/" && \
     wp_exec theme activate storefront; then
    echo "✅ Storefront instalado e ativado."
  else
    echo "⚠️  Falha ao instalar Storefront. Verifique a conexão de rede."
  fi
fi

echo "⚙️ Configurando wp-config.php..."
wp_exec config set DISABLE_WP_CRON true --raw
wp_exec config set WP_DEBUG true --raw
wp_exec config set WP_DEBUG_LOG true --raw
wp_exec config set WP_DEBUG_DISPLAY true --raw

echo "⚙️ Ativando plugin PayCrypto.Me..."
wp_exec plugin activate paycrypto-me-for-woocommerce 2>/dev/null || \
  echo "⚠️  Plugin não encontrado — verifique o mount em ./src/trunk"

echo ""
echo "✅ Setup completo!"
echo "🌐 http://localhost:8080"
echo "🔐 http://localhost:8080/wp-admin  (admin / admin123)"
